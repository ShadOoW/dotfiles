exec_always {
    ~/.config/sway/scripts/workspace-backgrounds.sh
}

exec {
    swayidle &
    autotiling-rs 3 4 5 6 7 8 9 10 &
    wl-paste --watch cliphist store &

    # Start MRU focus tracker for Alt-Tab behavior
    ~/.config/sway/scripts/sway_mru_daemon.py &

    # Pre-warm scratchpad apps — for_window rules handle mark + scratchpad
    kitty --app-id terminal-mark &
    kitty --app-id music-mark ncmpcpp &
    kitty --app-id yazi-explorer yazi &

    # Start browser
    vivaldi-stable &
}
