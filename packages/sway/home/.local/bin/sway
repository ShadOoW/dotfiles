#!/bin/sh
# Sway wrapper to capture logs to ~/.local/state/sway/logs/
# Force Intel iGPU for Wayland

LOGDIR="$HOME/.local/state/sway/logs"
LOGFILE="$LOGDIR/sway-$(date +%Y%m%d-%H%M%S).log"

mkdir -p "$LOGDIR"

echo "=== Sway wrapper started at $(date) ===" >"$LOGFILE"
echo "Log file: $LOGFILE" >>"$LOGFILE"
echo "PID: $$" >>"$LOGFILE"

INTEL_PATH="/dev/dri/by-path/pci-0000:00:02.0-card"
INTEL_DEV=$(readlink -f "$INTEL_PATH" 2>/dev/null)
export WLR_DRM_DEVICES="$INTEL_DEV"
echo "Using Intel GPU: $INTEL_DEV (from $INTEL_PATH)" >>"$LOGFILE"

exec /usr/bin/sway 2>>"$LOGFILE"
